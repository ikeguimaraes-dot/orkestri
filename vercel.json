{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/orchestrator/escalate",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/orchestrator/cron/compliance",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/orchestrator/cron/ferias",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/orchestrator/cron/folha",
      "schedule": "0 8 25 * *"
    },
    {
      "path": "/api/orchestrator/cron/onboarding",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/orchestrator/cron/score",
      "schedule": "30 8 * * 1"
    },
    {
      "path": "/api/orchestrator/cron/banco-horas",
      "schedule": "45 8 * * 1"
    },
    {
      "path": "/api/cron/learning-machine",
      "schedule": "0 11 * * 5"
    },
    {
      "path": "/api/cron/daily-summary",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/lorean-import",
      "schedule": "0 7 * * *"
    }
  ]
}
